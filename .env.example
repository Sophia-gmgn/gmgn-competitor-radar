# ============================================================
# 复制本文件为 .env 并填真实值（.env 已被 .gitignore，不会进仓库）。
# 上 GitHub Actions 时不用这个文件——改在仓库 Settings → Secrets and variables
# → Actions 里配同名 Secret。下面所有值现在都是占位，请人工替换。
# ============================================================

# —— Grok / xAI（抓取 + 研判）——
XAI_API_KEY="xai-你的KEY"
GROK_MODEL="grok-4.3"                 # 省钱可换 grok-4-1-fast

# —— Confluence（写页面）——
ATLASSIAN_EMAIL="你的Atlassian登录邮箱"
ATLASSIAN_API_TOKEN="你的Atlassian_API_Token"
CONFLUENCE_SITE="pionex.atlassian.net"
CONFLUENCE_SPACE_ID="224755860"
# 「X 话题日报」页面 ID：在 Confluence 打开那页，地址里的 pageId 数字
X_TOPICS_PAGE_ID=""
# 该页完整网址（Slack 日报末尾跳转用，可选）
X_TOPICS_PAGE_URL=""

# —— Slack（播报）——
SLACK_BOT_TOKEN="xoxb-你的BotToken"
SLACK_CHANNEL="C0BFFKSLC5D"           # GMGN竞品监控播报（和 Cynthia 同一个频道）

# —— 后续 Phase 会用到，先留空 ——
DISCORD_BOT_TOKEN=""
